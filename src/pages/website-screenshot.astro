---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Full Website Screenshot Tool — Capture Entire Webpage & Website to PDF | All YT DL"
  description="Free full website screenshot tool. Capture entire webpage from top to bottom in 4K retina quality. Download as PNG or convert website to PDF. The best webpage screenshot tool online."
>
  <!-- Hero Section -->
  <section class="flex flex-col items-center justify-center text-center gap-6 mt-6 mb-16 relative z-10" aria-labelledby="hero-title">
    <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline shadow-level-2 rounded-full" aria-label="Announcement">
      <span class="inline-block w-2 h-2 rounded-full bg-link animate-pulse" aria-hidden="true"></span>
      <span class="font-mono text-[10px] uppercase tracking-wider font-semibold text-primary">
        New Tool — Full-Page Screenshot
      </span>
    </div>

    <h1 id="hero-title" class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-display-xl text-primary leading-none text-wrap-balance">
      Capture any website,<br />end to end.
    </h1>

    <p class="max-w-[580px] text-base md:text-lg text-body-text leading-relaxed text-wrap-balance">
      Enter a URL and get a complete, ultra-high-resolution screenshot of any website — from the top of the page to the bottom. Every detail preserved. Download as PNG or PDF.
    </p>
  </section>

  <!-- Main Tool Container -->
  <section id="screenshot-tool" class="relative z-10 max-w-[900px] mx-auto mb-20" aria-label="Website Screenshot Tool">
    <div class="bg-canvas border border-hairline rounded-lg shadow-level-4 p-6 md:p-8 transition-all duration-300">

      <!-- URL Input Form -->
      <form id="screenshot-form" class="space-y-4" novalidate>
        <div class="flex flex-col gap-2">
          <label for="website-url" class="font-mono text-xs uppercase tracking-widest text-primary font-semibold">
            Enter Website URL
          </label>
          <div class="relative flex items-center shadow-level-2 bg-canvas border border-hairline rounded-sm focus-within:ring-2 focus-within:ring-primary/20 transition-all duration-200">
            <div class="pl-4 pr-2 text-mute" aria-hidden="true">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
              </svg>
            </div>
            <input
              id="website-url"
              name="website-url"
              type="text"
              required
              autocomplete="off"
              spellcheck="false"
              placeholder="e.g., example.com or https://example.com/page"
              class="w-full h-12 bg-transparent text-sm text-ink placeholder-mute focus:outline-none pr-4 font-mono"
            />
            <button
              id="btn-capture"
              type="submit"
              class="mr-2 h-8 px-4 bg-primary text-on-primary text-xs font-semibold rounded-xs shadow-level-2 hover:bg-primary/95 transition-colors cursor-pointer flex items-center gap-1.5 shrink-0"
            >
              <svg id="capture-icon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.16a15.53 15.53 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z" />
              </svg>
              <span id="capture-text">Capture</span>
              <span id="capture-spinner" class="hidden w-3.5 h-3.5 border-2 border-on-primary border-t-transparent rounded-full animate-spin"></span>
            </button>
          </div>
          <div id="form-error" class="hidden text-xs text-error font-medium mt-1 flex items-center gap-1.5" aria-live="polite">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span id="error-message">Please enter a valid URL.</span>
          </div>
        </div>
      </form>

      <!-- Loading State -->
      <div id="loading-state" class="hidden mt-8 p-6 border border-hairline bg-canvas-soft rounded-sm space-y-4 text-center">
        <div class="flex items-center justify-center gap-3">
          <div class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
          <span id="loading-status" class="text-sm font-mono text-body-text">Connecting to website…</span>
        </div>
        <div class="w-full max-w-[400px] mx-auto h-1 bg-hairline rounded-full overflow-hidden">
          <div id="loading-progress-bar" class="h-full bg-link transition-all duration-500 ease-out w-0"></div>
        </div>
        <p class="text-[10px] text-mute font-mono">This may take 15–45 seconds depending on the site</p>
      </div>

      <!-- Screenshot Result -->
      <div id="result-area" class="hidden mt-8 space-y-6 animate-fade-in">
        <div class="flex items-center justify-between flex-wrap gap-3">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-link" aria-hidden="true"></span>
            <h3 class="font-mono text-xs uppercase tracking-widest text-primary font-semibold">Captured Screenshot</h3>
          </div>
          <div class="flex items-center gap-2">
            <span id="screenshot-dimensions" class="text-[10px] text-mute font-mono"></span>
          </div>
        </div>

        <!-- Screenshot Display -->
        <div class="border border-hairline rounded-sm overflow-hidden bg-canvas-soft-2 shadow-level-2">
          <div class="overflow-auto max-h-[600px]">
            <img
              id="screenshot-img"
              src=""
              alt="Website screenshot"
              class="w-full object-top"
              style="image-rendering: auto;"
            />
          </div>
        </div>

        <!-- Download Buttons -->
        <div class="flex items-center gap-3 flex-wrap">
          <button
            id="btn-download-png"
            type="button"
            class="h-10 px-5 bg-primary text-on-primary text-sm font-semibold rounded-sm shadow-level-3 hover:bg-primary/95 transition-colors cursor-pointer flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            <span>Download PNG</span>
          </button>
          <button
            id="btn-download-pdf"
            type="button"
            class="h-10 px-5 bg-canvas border border-hairline hover:bg-canvas-soft-2 text-primary text-sm font-semibold rounded-sm shadow-level-2 transition-colors cursor-pointer flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            <span>Download PDF</span>
          </button>
          <button
            id="btn-capture-new"
            type="button"
            class="h-10 px-5 bg-canvas border border-hairline hover:bg-canvas-soft-2 text-primary text-sm font-medium rounded-sm shadow-level-2 transition-colors cursor-pointer flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
            </svg>
            <span>Capture New</span>
          </button>
        </div>

        <!-- Quick Tip -->
        <div class="p-3 bg-canvas-soft border border-hairline rounded-sm">
          <p class="text-[10px] text-mute font-mono">
            <span class="font-semibold text-primary">Tip:</span> The PDF version is ideal for sharing complete website designs with clients or teammates. The PNG is best for quick visual reference.
          </p>
        </div>
      </div>

      <!-- Welcome Guide -->
      <div id="welcome-guide" class="mt-8 border border-hairline bg-canvas-soft rounded-sm p-5 md:p-6 text-center">
        <h3 class="font-mono text-[11px] uppercase tracking-widest text-primary font-semibold mb-2">How It Works</h3>
        <p class="text-xs text-body-text leading-relaxed max-w-[520px] mx-auto">
          Paste any website URL and click Capture. Our engine launches a headless 4K browser, loads the full page, scrolls through to trigger all content, and captures every pixel from top to bottom.
        </p>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="relative z-10 max-w-[1200px] mx-auto border-t border-hairline pt-16 mb-20" aria-labelledby="features-title">
    <div class="text-center max-w-[600px] mx-auto mb-12">
      <h2 id="features-title" class="font-mono text-xs uppercase tracking-widest text-primary font-semibold mb-2">Built for Designers & Developers</h2>
      <p class="text-xl md:text-2xl font-semibold tracking-display-md text-primary text-pretty leading-none">
        Full-fidelity captures, every time.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3">
        <div class="w-8 h-8 rounded-full bg-link/10 text-link flex items-center justify-center mb-4" aria-hidden="true">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-primary tracking-display-sm">Full-Page Capture</h3>
        <p class="text-xs text-body-text mt-2 leading-relaxed">
          Captures every section from the top of the page to the bottom — including content loaded on scroll. Nothing is missed.
        </p>
      </div>

      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3">
        <div class="w-8 h-8 rounded-full bg-violet/10 text-violet flex items-center justify-center mb-4" aria-hidden="true">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-primary tracking-display-sm">4K Retina Quality</h3>
        <p class="text-xs text-body-text mt-2 leading-relaxed">
          Rendered at 3840px wide with 2x device scale for razor-sharp text and pixel-perfect details — even the smallest elements.
        </p>
      </div>

      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3">
        <div class="w-8 h-8 rounded-full bg-cyan-deep/10 text-cyan-deep flex items-center justify-center mb-4" aria-hidden="true">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-primary tracking-display-sm">PNG & PDF Export</h3>
        <p class="text-xs text-body-text mt-2 leading-relaxed">
          Download as high-resolution PNG for reference or as a formatted PDF to share complete website designs with clients and teammates.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does it take to capture a screenshot?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most simple sites capture in 10-20 seconds. Larger or media-heavy sites may take up to 45 seconds. The tool launches a real headless Chromium browser that fully loads every page before capturing."
        }
      },
      {
        "@type": "Question",
        "name": "Is this website screenshot tool free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! The tool is completely free to use with no limits on the number of captures. There are no sign-ups, no hidden fees, and no watermarks on your screenshots."
        }
      },
      {
        "@type": "Question",
        "name": "Does it capture the full page or just what I see on screen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It captures the entire page from top to bottom, not just the visible viewport. The tool scrolls through the full page height and produces a single composite screenshot showing every element."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between PNG and PDF?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The PNG is a single high-resolution image of the full page - great for quick viewing or inserting into documents. The PDF is a properly formatted document with selectable text, ideal for sharing with clients or printing."
        }
      },
      {
        "@type": "Question",
        "name": "What viewport resolution is used?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Screenshots are captured at 3840 pixels wide at 2x retina quality, ensuring crisp, ultra-high-resolution images that look sharp on any display."
        }
      },
      {
        "@type": "Question",
        "name": "Are there any websites that won't work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sites that require login, have bot protection, or block headless browsers may not render fully. Most public websites work flawlessly."
        }
      },
      {
        "@type": "Question",
        "name": "Is my data secure when using this tool?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We do not store any screenshots on our servers. Once generated, the image or PDF is streamed directly to your browser for download. No copies are retained."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use this tool on my phone or tablet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! The interface is fully responsive and works on any device with a modern browser. You can capture website screenshots from your phone, tablet, or desktop."
        }
      },
      {
        "@type": "Question",
        "name": "Can I capture password-protected pages or pages behind a login?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The tool can only capture publicly accessible pages. Password-protected pages, member-only areas, and pages behind authentication will not render correctly."
        }
      }
    ]
  }
  </script>

  <!-- FAQ Section -->
  <section id="faq" class="relative z-10 max-w-[800px] mx-auto border-t border-hairline pt-16 mb-20" aria-labelledby="faq-title">
    <div class="text-center mb-10">
      <h2 id="faq-title" class="font-mono text-xs uppercase tracking-widest text-primary font-semibold mb-2">FAQ</h2>
      <p class="text-xl md:text-2xl font-semibold tracking-display-md text-primary text-pretty leading-none">
        Common Questions
      </p>
    </div>

    <div class="space-y-4">
      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>How long does it take to capture a screenshot?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          Most simple sites capture in 10-20 seconds. Larger or media-heavy sites may take up to 45 seconds. The tool launches a real headless Chromium browser that fully loads every page before capturing.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>Is this tool free?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          Yes! The tool is completely free to use with no limits on the number of captures. There are no sign-ups, no hidden fees, and no watermarks on your screenshots.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>Does it capture the full page or just the screen?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          It captures the entire website from top to bottom, not just the visible viewport. The tool scrolls through the full page height and produces a single composite screenshot showing every element.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>What&apos;s the difference between PNG and PDF?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          The PNG is a single high-resolution image of the full page - great for quick viewing or inserting into documents. The PDF is a properly formatted document with selectable text, ideal for sharing with clients or printing.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>What viewport resolution is used?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          Screenshots are captured at 3840 pixels wide at 2x retina quality, ensuring crisp, ultra-high-resolution images that look sharp on any display.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>Are there any websites that won&apos;t work?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          Sites that require login, have bot protection, or block headless browsers may not render fully. Most public websites work flawlessly.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>Is my data secure?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          Yes. We do not store any screenshots on our servers. Once generated, the image or PDF is streamed directly to your browser for download. No copies are retained.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>Can I use this on my phone or tablet?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          Yes! The interface is fully responsive and works on any device with a modern browser. You can capture website screenshots from your phone, tablet, or desktop.
        </div>
      </details>

      <details class="group bg-canvas border border-hairline rounded-sm shadow-level-1 overflow-hidden transition-all duration-200">
        <summary class="flex justify-between items-center p-4 font-semibold text-xs uppercase tracking-wider text-primary cursor-pointer select-none hover:bg-canvas-soft-2 focus:outline-none focus-visible:bg-canvas-soft-2 list-none">
          <span>Can I capture password-protected pages?</span>
          <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="p-4 border-t border-hairline text-xs text-body-text leading-relaxed bg-canvas-soft">
          No. The tool can only capture publicly accessible pages. Password-protected pages, member-only areas, and pages behind authentication will not render correctly.
        </div>
      </details>
    </div>
  </section>

  <script is:inline>
    (function() {
      var form = document.getElementById('screenshot-form');
      var urlInput = document.getElementById('website-url');
      var btnCapture = document.getElementById('btn-capture');
      var captureIcon = document.getElementById('capture-icon');
      var captureSpinner = document.getElementById('capture-spinner');
      var captureText = document.getElementById('capture-text');
      var formError = document.getElementById('form-error');
      var errorMessage = document.getElementById('error-message');
      var loadingState = document.getElementById('loading-state');
      var loadingStatus = document.getElementById('loading-status');
      var loadingProgressBar = document.getElementById('loading-progress-bar');
      var resultArea = document.getElementById('result-area');
      var screenshotImg = document.getElementById('screenshot-img');
      var screenshotDimensions = document.getElementById('screenshot-dimensions');
      var btnDownloadPng = document.getElementById('btn-download-png');
      var btnDownloadPdf = document.getElementById('btn-download-pdf');
      var btnCaptureNew = document.getElementById('btn-capture-new');
      var welcomeGuide = document.getElementById('welcome-guide');

      var capturedUrl = '';
      var capturedBlobUrl = '';

      function showValidationError(msg) {
        errorMessage.textContent = msg;
        formError.classList.remove('hidden');
        urlInput.classList.add('border-error');
        urlInput.focus();
      }

      function clearValidationError() {
        formError.classList.add('hidden');
        urlInput.classList.remove('border-error');
      }

      function setLoading(loading) {
        if (loading) {
          captureIcon.classList.add('hidden');
          captureSpinner.classList.remove('hidden');
          captureText.textContent = 'Capturing\u2026';
          btnCapture.disabled = true;
          loadingState.classList.remove('hidden');
          resultArea.classList.add('hidden');
          welcomeGuide.classList.add('hidden');
          loadingProgressBar.style.width = '0%';
          loadingStatus.textContent = 'Connecting to website\u2026';
        } else {
          captureIcon.classList.remove('hidden');
          captureSpinner.classList.add('hidden');
          captureText.textContent = 'Capture';
          btnCapture.disabled = false;
          loadingState.classList.add('hidden');
        }
      }

      function simulateProgress() {
        var stages = [
          { pct: 10, label: 'Launching headless browser\u2026', delay: 2000 },
          { pct: 25, label: 'Navigating to website\u2026', delay: 5000 },
          { pct: 45, label: 'Waiting for page to load\u2026', delay: 10000 },
          { pct: 65, label: 'Scrolling for lazy content\u2026', delay: 15000 },
          { pct: 80, label: 'Rendering full page\u2026', delay: 20000 },
          { pct: 92, label: 'Capturing screenshot\u2026', delay: 28000 },
        ];
        var startTime = Date.now();
        var currentIndex = 0;

        function update() {
          if (!loadingState.classList.contains('hidden')) {
            var elapsed = Date.now() - startTime;
            while (currentIndex < stages.length - 1 && elapsed >= stages[currentIndex + 1].delay) {
              currentIndex++;
            }
            var stage = stages[currentIndex];
            loadingProgressBar.style.width = stage.pct + '%';
            loadingStatus.textContent = stage.label;

            if (currentIndex < stages.length - 1) {
              var nextStage = stages[currentIndex + 1];
              var progressInStage = (elapsed - stage.delay) / (nextStage.delay - stage.delay);
              var currentPct = stage.pct + (nextStage.pct - stage.pct) * Math.min(1, progressInStage);
              loadingProgressBar.style.width = Math.min(currentPct, 95) + '%';
            } else {
              loadingProgressBar.style.width = '95%';
            }

            requestAnimationFrame(update);
          }
        }
        requestAnimationFrame(update);
      }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        clearValidationError();

        var rawUrl = urlInput.value.trim();
        if (!rawUrl) {
          showValidationError('Please enter a website URL.');
          return;
        }

        // Basic URL validation
        var testUrl;
        try {
          testUrl = new URL(rawUrl.startsWith('http://') || rawUrl.startsWith('https://') ? rawUrl : 'https://' + rawUrl);
        } catch (err) {
          showValidationError('Please enter a valid URL (e.g., example.com).');
          return;
        }

        setLoading(true);
        capturedUrl = testUrl.href;
        simulateProgress();

        try {
          var apiUrl = '/api/screenshot?url=' + encodeURIComponent(capturedUrl) + '&format=png&t=' + Date.now();
          var response = await fetch(apiUrl);

          if (!response.ok) {
            var errData;
            try { errData = await response.json(); } catch (e) {}
            throw new Error((errData && errData.error) || 'Screenshot capture failed (HTTP ' + response.status + ')');
          }

          var blob = await response.blob();
          var objectUrl = URL.createObjectURL(blob);

          if (capturedBlobUrl) {
            URL.revokeObjectURL(capturedBlobUrl);
          }
          capturedBlobUrl = objectUrl;

          screenshotImg.src = objectUrl;
          screenshotImg.onload = function() {
            var w = screenshotImg.naturalWidth;
            var h = screenshotImg.naturalHeight;
            screenshotDimensions.textContent = w + ' \u00d7 ' + h + ' px';
          };

          setLoading(false);
          loadingProgressBar.style.width = '100%';
          loadingStatus.textContent = 'Complete!';
          resultArea.classList.remove('hidden');
        } catch (err) {
          console.error('Screenshot error:', err);
          setLoading(false);
          showValidationError(err.message || 'Failed to capture screenshot. The site may be unreachable or blocking automated access.');
        }
      });

      // Download PNG
      btnDownloadPng.addEventListener('click', function() {
        if (!capturedUrl) return;
        var a = document.createElement('a');
        a.href = '/api/screenshot?url=' + encodeURIComponent(capturedUrl) + '&format=png&t=' + Date.now();
        a.download = 'screenshot.png';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      });

      // Download PDF
      btnDownloadPdf.addEventListener('click', function() {
        if (!capturedUrl) return;
        var a = document.createElement('a');
        a.href = '/api/screenshot?url=' + encodeURIComponent(capturedUrl) + '&format=pdf&t=' + Date.now();
        a.download = 'screenshot.pdf';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      });

      // Capture New
      btnCaptureNew.addEventListener('click', function() {
        if (capturedBlobUrl) {
          URL.revokeObjectURL(capturedBlobUrl);
          capturedBlobUrl = '';
        }
        capturedUrl = '';
        screenshotImg.src = '';
        resultArea.classList.add('hidden');
        welcomeGuide.classList.remove('hidden');
        urlInput.value = '';
        urlInput.focus();
        clearValidationError();
      });

      urlInput.addEventListener('input', function() {
        clearValidationError();
      });
    })();
  </script>
</Layout>
