      function extractYouTubeId(url) {
        if (!url) return null;
        // Standard, Shorts, Embeds, Shared links, Mobile, YouTube Music
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|shorts\/|music\.youtube\.com\/watch\?v=)([^#\&\?]*).*/;
        const match = url.trim().match(regExp);
        if (match && match[2] && match[2].length === 11) {
          return match[2];
        }
        // Direct ID paste (11 alphanumeric characters)
        const idReg = /^[a-zA-Z0-9_-]{11}$/;
        if (idReg.test(url.trim())) {
          return url.trim();
        }
        return null;
      }

      function showValidationError(msg) {
        errorMessage.textContent = msg;
        formError.classList.remove('hidden');
        urlInput.classList.add('border-error');
        urlInput.classList.add('focus-within:ring-error/20');
        urlInput.focus();
      }

      function clearValidationError() {
        formError.classList.add('hidden');
        urlInput.classList.remove('border-error');
        urlInput.classList.remove('focus-within:ring-error/20');
      }

      function setSubmitLoading(loading) {
        isFetching = loading;
        if (loading) {
          submitIcon.classList.add('hidden');
          submitSpinner.classList.remove('hidden');
          btnSubmit.disabled = true;
        } else {
          submitIcon.classList.remove('hidden');
          submitSpinner.classList.add('hidden');
          btnSubmit.disabled = false;
        }
      }

      // ──────────────── TABS TOGGLE ────────────────
      function switchTab(tab) {
        currentTab = tab;
        if (tab === 'video') {
          // Tab button styles
          tabVideo.classList.add('bg-primary', 'text-on-primary', 'shadow-level-2');
          tabVideo.classList.remove('text-body-text', 'hover:text-primary', 'hover:bg-canvas-soft');
          tabVideo.setAttribute('aria-selected', 'true');
          
          tabThumbnail.classList.remove('bg-primary', 'text-on-primary', 'shadow-level-2');
          tabThumbnail.classList.add('text-body-text', 'hover:text-primary', 'hover:bg-canvas-soft');
          tabThumbnail.setAttribute('aria-selected', 'false');
          
          // View visibility
          panelVideo.classList.remove('hidden');
          panelThumbnail.classList.add('hidden');
        } else {
          // Tab button styles
          tabThumbnail.classList.add('bg-primary', 'text-on-primary', 'shadow-level-2');
          tabThumbnail.classList.remove('text-body-text', 'hover:text-primary', 'hover:bg-canvas-soft');
          tabThumbnail.setAttribute('aria-selected', 'true');
          
          tabVideo.classList.remove('bg-primary', 'text-on-primary', 'shadow-level-2');
          tabVideo.classList.add('text-body-text', 'hover:text-primary', 'hover:bg-canvas-soft');
          tabVideo.setAttribute('aria-selected', 'false');
          
          // View visibility
          panelThumbnail.classList.remove('hidden');
          panelVideo.classList.add('hidden');
        }
      }

      tabVideo.addEventListener('click', () => switchTab('video'));
      tabThumbnail.addEventListener('click', () => switchTab('thumbnail'));

      // ──────────────── INPUT INTERACTIONS ────────────────
      urlInput.addEventListener('input', () => {
        clearValidationError();
        if (urlInput.value.length > 0) {
          btnReset.classList.remove('hidden');
        } else {
          btnReset.classList.add('hidden');
        }
      });

      btnReset.addEventListener('click', () => {
        urlInput.value = '';
        btnReset.classList.add('hidden');
        clearValidationError();
        welcomeGuide.classList.remove('hidden');
        resultsPanel.classList.add('hidden');
        activeVideoId = null;
        activeVideoUrl = '';
        videoMetadata = null;
        
        // Reset fallback console
        fallbackBox.classList.add('hidden');
        btnDownloadVideo.disabled = false;
        urlInput.focus();
      });

      // ──────────────── RETRIEVE DETAILS (oEmbed via Proxy) ────────────────
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearValidationError();
        
        const rawUrl = urlInput.value.trim();
        if (!rawUrl) {
          showValidationError('Please paste a YouTube video link.');
          return;
        }

        const videoId = extractYouTubeId(rawUrl);
        if (!videoId) {
          showValidationError('Could not extract a valid YouTube Video ID. Please check the URL.');
          return;
        }

        setSubmitLoading(true);
        activeVideoId = videoId;
        // Construct canonical URL
        activeVideoUrl = `https://www.youtube.com/watch?v=${videoId}`;
        
        // Reset download panel state
        fallbackBox.classList.add('hidden');
        btnDownloadVideo.disabled = false;

        try {
          // Attempt to retrieve oEmbed metadata via a CORS proxy (corsproxy.io is fast and free)
          const targetOembedUrl = `https://www.youtube.com/oembed?url=${encodeURIComponent(activeVideoUrl)}&format=json`;
          const proxyUrl = `https://corsproxy.io/?${encodeURIComponent(targetOembedUrl)}`;
          
          const response = await fetch(proxyUrl);
          if (!response.ok) {
            throw new Error('Metadata fetch failed');
          }
          
          const data = await response.json();
          videoMetadata = data;
          
          // Populate metadata
          metaTitle.textContent = data.title || 'YouTube Video';
          metaAuthor.textContent = data.author_name || 'Creator';
        } catch (error) {
          console.warn('oEmbed metadata retrieval via proxy failed. Falling back to generic details.', error);
          // Graceful fallback to avoid rendering a broken screen
          metaTitle.textContent = `YouTube Video (${videoId})`;
          metaAuthor.textContent = 'YouTube Creator';
        } finally {
          metaId.textContent = videoId;
          const mainThumb = `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;
          metaThumbnail.src = mainThumb;

          // Configure thumbnail image sources for downstream download cards
          const thumbMax = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
          const thumbSd = `https://img.youtube.com/vi/${videoId}/sddefault.jpg`;
          const thumbHq = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
          const thumbMq = `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;

          thumbImgMax.src = thumbMax;
          thumbImgSd.src = thumbSd;
          thumbImgHq.src = thumbHq;
          thumbImgMq.src = thumbMq;

          // Check if resolutions actually load (some older videos lack maxresdefault or sddefault)
          // Hide or replace cards dynamically if the resolution yields a 404 (YouTube returns placeholder images or fails)
          checkImageExists(thumbMax).then(exists => {
            if (!exists) {
              cardMax.classList.add('opacity-50', 'pointer-events-none');
              thumbImgMax.style.filter = 'grayscale(1)';
            } else {
              cardMax.classList.remove('opacity-50', 'pointer-events-none');
              thumbImgMax.style.filter = 'none';
            }
          });

          checkImageExists(thumbSd).then(exists => {
            if (!exists) {
              cardSd.classList.add('opacity-50', 'pointer-events-none');
              thumbImgSd.style.filter = 'grayscale(1)';
            } else {
              cardSd.classList.remove('opacity-50', 'pointer-events-none');
              thumbImgSd.style.filter = 'none';
            }
          });

          // Fetch available video formats for quality/size information

          fetch(`/api/formats?videoUrl=${encodeURIComponent(activeVideoUrl)}`)
            .then(r => r.json())
            .then(data => {
              ytFormats = data.formats;

              // Update quality dropdown labels with file sizes
              const sel = document.getElementById('video-resolution');
              if (sel) {
                const options = sel.querySelectorAll('option');
                options.forEach(opt => {
                  const val = opt.value;
                  if (val === 'mp3') {
                    const audio = data.formats?.audio?.[0];
                    if (audio?.size) opt.textContent = `MP3 Audio (${(audio.size / 1024 / 1024).toFixed(1)} MB)`;
                    return;
                  }
                  const combined = data.formats?.combined?.filter(f => {
                    const h = f.height;
                    return val === '1085' ? h >= 1080 : val === '720' ? h >= 720 && h < 1080 : val === '480' ? h >= 480 && h < 720 : h >= 360 && h < 480;
                  });
                  if (combined?.[0]?.size) {
                    opt.textContent = opt.textContent.replace(/\(.*?\)/, `(${(combined[0].size / 1024 / 1024).toFixed(0)} MB)`);
                  }
                });
              }
            })
            .catch(() => {});

          setSubmitLoading(false);
          welcomeGuide.classList.add('hidden');
          resultsPanel.classList.remove('hidden');
        }
      });

      // Helper to check if YouTube image resource is a real resolution or placeholder (YouTube redirects 404 thumbnails to a 120px default image)
      function checkImageExists(url) {
        return new Promise((resolve) => {
          const img = new Image();
          img.onload = () => {
            // YouTube placeholder for missing maxres is exactly 120x90
            if (img.width === 120 && img.height === 90) {
              resolve(false);
            } else {
              resolve(true);
            }
          };
          img.onerror = () => resolve(false);
          img.src = url;
        });
      }

      // ──────────────── THUMBNAIL DOWNLOAD PROCESS ────────────────
      document.querySelectorAll('.btn-download-thumb').forEach(button => {
        button.addEventListener('click', async (e) => {
          const type = button.getAttribute('data-type');
          if (!activeVideoId || !type) return;

          const originalContent = button.innerHTML;
          button.disabled = true;
          button.innerHTML = `
            <svg class="w-3.5 h-3.5 border-2 border-on-primary border-t-transparent rounded-full animate-spin" viewBox="0 0 24 24"></svg>
            <span>Downloading...</span>
          `;

          try {
            const rawImgUrl = `https://img.youtube.com/vi/${activeVideoId}/${type}.jpg`;
            const proxyUrl = `https://corsproxy.io/?${encodeURIComponent(rawImgUrl)}`;
            const response = await fetch(proxyUrl);
            if (!response.ok) throw new Error('Fetch failed');
            const blob = await response.blob();
            const blobUrl = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = `${activeVideoId}_${type}.jpg`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(blobUrl);
          } catch (err) {
            console.error('Thumbnail download error:', err);
            // Fallback: direct link (may open in new tab)
            window.open(`https://img.youtube.com/vi/${activeVideoId}/${type}.jpg`, '_blank');
          } finally {
            button.innerHTML = originalContent;
            button.disabled = false;
          }
        });
      });

      // ──────────────── COPY THUMBNAIL TO CLIPBOARD ────────────────
      document.querySelectorAll('.btn-copy-thumb').forEach(button => {
        button.addEventListener('click', async (e) => {
          const type = button.getAttribute('data-type');
          if (!activeVideoId || !type) return;

          const originalContent = button.innerHTML;
          button.disabled = true;
          button.innerHTML = `
            <svg class="w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin" viewBox="0 0 24 24"></svg>
          `;

          try {
            const rawImgUrl = `https://img.youtube.com/vi/${activeVideoId}/${type}.jpg`;
            const proxyImgUrl = `https://corsproxy.io/?${encodeURIComponent(rawImgUrl)}`;
            
            const response = await fetch(proxyImgUrl);
            if (!response.ok) throw new Error('Image copy failed');
            
            const blob = await response.blob();
            
            // Convert JPEG blob to PNG client-side because browsers only support copying PNGs to clipboard
            const img = new Image();
            const localBlobUrl = URL.createObjectURL(blob);
            
            img.onload = async () => {
              const canvas = document.createElement('canvas');
              canvas.width = img.width;
              canvas.height = img.height;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0);
              
              canvas.toBlob(async (pngBlob) => {
                try {
                  await navigator.clipboard.write([
                    new ClipboardItem({ 'image/png': pngBlob })
                  ]);
                  // Show Success Toast temporary state
                  button.innerHTML = `
                    <svg class="w-4 h-4 text-link" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  `;
                  setTimeout(() => {
                    button.innerHTML = originalContent;
                    button.disabled = false;
                  }, 2000);
                } catch (writeErr) {
                  console.error('Clipboard write block', writeErr);
                  alert('Clipboard blocked. Please copy image manually.');
                  button.innerHTML = originalContent;
                  button.disabled = false;
                }
                URL.revokeObjectURL(localBlobUrl);
              }, 'image/png');
            };
            img.src = localBlobUrl;
          } catch (err) {
            console.error('Unable to fetch and copy image blob', err);
            // Copy plain text link as fallback
            try {
              await navigator.clipboard.writeText(`https://img.youtube.com/vi/${activeVideoId}/${type}.jpg`);
              button.innerHTML = `
                <svg class="w-4 h-4 text-link" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              `;
              setTimeout(() => {
                button.innerHTML = originalContent;
                button.disabled = false;
              }, 2000);
            } catch (clipErr) {
              button.innerHTML = originalContent;
              button.disabled = false;
            }
          }
        });
      });

      // ──────────────── VIDEO DOWNLOAD ────────────────
      // All downloads are processed server-side via yt-dlp on the backend.
      // The server downloads the video, merges streams if needed, and streams
      // the result back to the client as a file download.
      btnDownloadVideo.addEventListener('click', async () => {
        if (!activeVideoUrl) return;

        const targetRes = valResolution.value;
        const isAudioOnly = targetRes === 'mp3';
        const quality = isAudioOnly ? '720' : targetRes;

        const downloadUrl = `/api/download?videoUrl=${encodeURIComponent(activeVideoUrl)}&quality=${quality}&audioOnly=${isAudioOnly}`;

        // Show loading state
        btnDownloadVideo.disabled = true;
        const originalContent = btnDownloadVideo.innerHTML;
        btnDownloadVideo.innerHTML = `
          <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          <span>Downloading...</span>
        `;

        try {
          const response = await fetch(downloadUrl);
          if (!response.ok) {
            const errData = await response.json().catch(() => ({ message: 'Download failed' }));
            throw new Error(errData.message || 'Download failed');
          }

          const blob = await response.blob();
          const blobUrl = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = blobUrl;
          a.download = `yt-download.${isAudioOnly ? 'm4a' : 'mp4'}`;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(blobUrl);

          fallbackBox.classList.add('hidden');
        } catch (err) {
          console.error('Download error:', err);
          if (fallbackErrorMsg) {
            fallbackErrorMsg.textContent = err.message || 'Download failed. Please try again.';
          }
          fallbackBox.classList.remove('hidden');
        } finally {
          btnDownloadVideo.disabled = false;
          btnDownloadVideo.innerHTML = originalContent;
        }
      });
    })();
  </script>
</Layout>
