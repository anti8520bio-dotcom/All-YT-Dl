---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="All YT DL — Free YouTube Video Download & Thumbnail Downloader Online"
  description="All YT DL is your all-in-one online toolkit. Download YouTube videos in HD, 4K, and MP3 for free. Grab YouTube thumbnails in 4K. Convert images to text with OCR. Capture full website screenshots and export to PDF. Fast, ad-free, and private."
>
  <!-- Hero Section -->
  <section class="flex flex-col items-center justify-center text-center gap-6 mt-6 mb-16 relative z-10" aria-labelledby="hero-title">
    <!-- Announcement Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline shadow-level-2 rounded-full hover:scale-[1.02] transition-transform duration-200" aria-label="Announcement">
      <span class="inline-block w-2 h-2 rounded-full bg-link animate-pulse" aria-hidden="true"></span>
      <span class="font-mono text-[10px] uppercase tracking-wider font-semibold text-primary">
        Introducing ALL YT DL&nbsp;v1.0
      </span>
    </div>

    <!-- Main Title -->
    <h1 id="hero-title" class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-display-xl text-primary leading-none text-wrap-balance">
      All YouTube downloads,<br />simplified.
    </h1>
    
    <!-- Subtitle -->
    <p class="max-w-[580px] text-base md:text-lg text-body-text leading-relaxed text-wrap-balance">
      A stark, ad-free developer utility to grab high-resolution thumbnails and extract video/audio streams instantly. No redirects. No spam. Just the files.
    </p>
  </section>

  <!-- Main Tool Container -->
  <section id="downloader" class="relative z-10 max-w-[800px] mx-auto mb-20" aria-label="YouTube Downloader Tool">
    <!-- Feature Toggles (Vercel tab-ghost style) -->
    <div class="flex justify-center mb-8" role="tablist" aria-label="Tool Features">
      <div class="flex items-center gap-1 bg-canvas-soft-2 p-1 rounded-full shadow-level-1 border border-hairline">
        <button 
          id="tab-video" 
          type="button"
          class="px-5 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider transition-all duration-200 cursor-pointer bg-primary text-on-primary shadow-level-2"
          role="tab"
          aria-selected="true"
          aria-controls="panel-video"
          aria-label="Switch to Video and Audio Downloader"
        >
          Video Downloader
        </button>
        <button 
          id="tab-thumbnail" 
          type="button"
          class="px-5 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider transition-all duration-200 cursor-pointer text-body-text hover:text-primary hover:bg-canvas-soft"
          role="tab"
          aria-selected="false"
          aria-controls="panel-thumbnail"
          aria-label="Switch to Thumbnail Grabber"
        >
          Thumbnail Grabber
        </button>
      </div>
    </div>

    <!-- Tool Card (Vercel card-marketing-large style) -->
    <div class="bg-canvas border border-hairline rounded-lg shadow-level-4 p-6 md:p-8 transition-all duration-300">
      
      <!-- Input Form -->
      <form id="downloader-form" class="space-y-4" novalidate>
        <div class="flex flex-col gap-2">
          <label for="youtube-url" class="font-mono text-xs uppercase tracking-widest text-primary font-semibold">
            Paste YouTube Video URL
          </label>
          <div class="relative flex items-center shadow-level-2 bg-canvas border border-hairline rounded-sm focus-within:ring-2 focus-within:ring-primary/20 transition-all duration-200">
            <!-- Icon -->
            <div class="pl-4 pr-2 text-mute" aria-hidden="true">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
              </svg>
            </div>
            
            <!-- URL Input -->
            <input 
              id="youtube-url"
              name="youtube-url"
              type="url"
              required
              autocomplete="off"
              spellcheck="false"
              placeholder="e.g., https://www.youtube.com/watch?v=dQw4w9WgXcQ…"
              class="w-full h-12 bg-transparent text-sm text-ink placeholder-mute focus:outline-none pr-12 font-mono"
            />
            
            <!-- Reset Button -->
            <button 
              id="btn-reset" 
              type="button" 
              class="absolute right-12 text-mute hover:text-primary p-2 hidden cursor-pointer"
              aria-label="Clear url input"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
            
            <!-- Submit Icon Action -->
            <button 
              id="btn-submit" 
              type="submit"
              class="absolute right-2 p-2 bg-primary text-on-primary hover:bg-primary/95 rounded-xs transition-colors shadow-level-2 cursor-pointer h-8 w-8 flex items-center justify-center"
              aria-label="Retrieve video resources"
            >
              <span id="submit-spinner" class="hidden w-4 h-4 border-2 border-on-primary border-t-transparent rounded-full animate-spin"></span>
              <svg id="submit-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </button>
          </div>
          <!-- Error Feedback Container -->
          <div id="form-error" class="hidden text-xs text-error font-medium mt-1 flex items-center gap-1.5" aria-live="polite">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span id="error-message">Please enter a valid YouTube video URL.</span>
          </div>
        </div>
      </form>

      <!-- Welcome Guide Frame -->
      <div id="welcome-guide" class="mt-8 border border-hairline bg-canvas-soft rounded-sm p-5 md:p-6 text-center">
        <h3 class="font-mono text-[11px] uppercase tracking-widest text-primary font-semibold mb-2">How It Works</h3>
        <p class="text-xs text-body-text leading-relaxed max-w-[480px] mx-auto">
          Paste any standard video link, YouTube Short, or channel share URL. The tool will instantly query video details and prepare raw high-quality direct download nodes.
        </p>
      </div>

      <!-- Dashboard Results Panel (Hidden initially) -->
      <div id="results-panel" class="hidden mt-8 space-y-8 animate-fade-in">
        
        <!-- Video Metadata Summary -->
        <div class="flex flex-col md:flex-row gap-5 p-4 bg-canvas-soft border border-hairline rounded-sm">
          <div class="relative w-full md:w-44 aspect-video rounded-sm overflow-hidden bg-canvas-soft-2 border border-hairline shadow-level-1 shrink-0">
            <img id="meta-thumbnail" src="" alt="YouTube Video Preview" class="w-full h-full object-cover" width="176" height="99" />
          </div>
          <div class="flex flex-col justify-between py-1 min-w-0">
            <div>
              <span id="meta-author" class="font-mono text-[10px] uppercase tracking-wider text-mute font-semibold">
                Channel Name
              </span>
              <h2 id="meta-title" class="text-base md:text-lg font-semibold tracking-display-md text-primary mt-1 truncate text-wrap-balance leading-snug">
                Video Title
              </h2>
            </div>
            <div class="flex items-center gap-2 mt-3 font-mono text-[11px] text-mute">
              <span>ID: <code id="meta-id" class="text-primary font-semibold">dQw4w9WgXcQ</code></span>
            </div>
          </div>
        </div>

        <!-- ──────────────── PANELS ──────────────── -->

        <!-- A. VIDEO DOWNLOADER PANEL -->
        <div id="panel-video" class="space-y-6" role="tabpanel" aria-labelledby="tab-video">
          <div class="space-y-4">
            <div class="flex flex-col gap-2">
              <label for="video-resolution" class="font-mono text-xs uppercase tracking-widest text-primary font-semibold">
                Select Download Format
              </label>
              <div class="relative w-full max-w-[320px]">
                <select id="video-resolution" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-sm text-xs font-semibold text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 appearance-none cursor-pointer">
                  <option value="1085" selected>1080p MP4 — Full HD (Best Quality)</option>
                  <option value="720">720p MP4 — High Definition</option>
                  <option value="480">480p MP4 — Standard</option>
                  <option value="360">360p MP4 — Low-Res Web</option>
                  <option value="mp3">MP3 Audio — High Quality Extract</option>
                </select>
                <div class="absolute right-3 top-1/2 -translate-y-1/2 text-mute pointer-events-none" aria-hidden="true">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
            </div>

            <!-- Download Button Trigger -->
            <button 
              id="btn-download-video" 
              type="button"
              class="w-full h-11 bg-primary text-on-primary text-sm font-semibold rounded-sm shadow-level-3 hover:bg-primary/95 transition-colors cursor-pointer flex items-center justify-center gap-2"
              aria-label="Start video extraction"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              <span>Download Media</span>
            </button>

            <!-- Error Console (Hidden initially) -->
            <div id="download-fallback-box" class="hidden border border-error/20 bg-error-soft/10 rounded-sm p-5 space-y-3">
              <div class="flex gap-2">
                <svg class="w-4 h-4 text-error shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <div class="space-y-1">
                  <h4 class="text-xs font-semibold text-primary font-mono uppercase tracking-wider">Download Error</h4>
                  <p id="fallback-error-msg" class="text-xs text-body-text leading-relaxed">
                    Could not process this download. Please try again.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- B. THUMBNAIL GRABBER PANEL -->
        <div id="panel-thumbnail" class="hidden space-y-6" role="tabpanel" aria-labelledby="tab-thumbnail">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <!-- Thumbnail Option Card: MaxRes (1080p) -->
            <div class="border border-hairline bg-canvas rounded-sm overflow-hidden flex flex-col shadow-level-2 group" id="card-thumbnail-max">
              <div class="relative aspect-video bg-canvas-soft-2 border-b border-hairline overflow-hidden">
                <img id="thumb-img-max" src="" alt="Maximum Resolution Thumbnail" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" loading="lazy" />
                <span class="absolute top-2 left-2 px-2 py-0.5 bg-primary/80 backdrop-blur-sm text-on-primary font-mono text-[9px] rounded-sm font-semibold uppercase">
                  1080p MaxRes
                </span>
              </div>
              <div class="p-3 flex-grow flex flex-col justify-between gap-3">
                <div class="font-mono text-[10px] text-mute flex items-center justify-between">
                  <span>Dimension: 1920&nbsp;&times;&nbsp;1080</span>
                  <span class="text-primary font-semibold">HQ JPEG</span>
                </div>
                <div class="grid grid-cols-3 gap-2">
                  <button 
                    type="button" 
                    class="h-8 bg-primary hover:bg-primary/95 text-on-primary text-xs font-semibold rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center gap-1 col-span-2 btn-download-thumb"
                    data-type="maxresdefault"
                    aria-label="Download 1080p Maximum Resolution Thumbnail File"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                    <span>Download</span>
                  </button>
                  <button 
                    type="button" 
                    class="h-8 bg-canvas border border-hairline hover:bg-canvas-soft-2 text-primary text-xs font-medium rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center btn-copy-thumb"
                    data-type="maxresdefault"
                    aria-label="Copy 1080p Thumbnail to Clipboard"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-5 10v-3m0 0l-1.5 1.5M12 12l1.5 1.5" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>

            <!-- Thumbnail Option Card: High (720p / Standard) -->
            <div class="border border-hairline bg-canvas rounded-sm overflow-hidden flex flex-col shadow-level-2 group" id="card-thumbnail-sd">
              <div class="relative aspect-video bg-canvas-soft-2 border-b border-hairline overflow-hidden">
                <img id="thumb-img-sd" src="" alt="Standard Resolution Thumbnail" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" loading="lazy" />
                <span class="absolute top-2 left-2 px-2 py-0.5 bg-primary/80 backdrop-blur-sm text-on-primary font-mono text-[9px] rounded-sm font-semibold uppercase">
                  720p Standard
                </span>
              </div>
              <div class="p-3 flex-grow flex flex-col justify-between gap-3">
                <div class="font-mono text-[10px] text-mute flex items-center justify-between">
                  <span>Dimension: 1280&nbsp;&times;&nbsp;720</span>
                  <span class="text-primary font-semibold">HQ JPEG</span>
                </div>
                <div class="grid grid-cols-3 gap-2">
                  <button 
                    type="button" 
                    class="h-8 bg-primary hover:bg-primary/95 text-on-primary text-xs font-semibold rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center gap-1 col-span-2 btn-download-thumb"
                    data-type="sddefault"
                    aria-label="Download 720p Standard Resolution Thumbnail File"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                    <span>Download</span>
                  </button>
                  <button 
                    type="button" 
                    class="h-8 bg-canvas border border-hairline hover:bg-canvas-soft-2 text-primary text-xs font-medium rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center btn-copy-thumb"
                    data-type="sddefault"
                    aria-label="Copy 720p Thumbnail to Clipboard"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-5 10v-3m0 0l-1.5 1.5M12 12l1.5 1.5" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>

            <!-- Thumbnail Option Card: HQ (480p) -->
            <div class="border border-hairline bg-canvas rounded-sm overflow-hidden flex flex-col shadow-level-2 group" id="card-thumbnail-hq">
              <div class="relative aspect-video bg-canvas-soft-2 border-b border-hairline overflow-hidden">
                <img id="thumb-img-hq" src="" alt="High Quality Thumbnail" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" loading="lazy" />
                <span class="absolute top-2 left-2 px-2 py-0.5 bg-primary/80 backdrop-blur-sm text-on-primary font-mono text-[9px] rounded-sm font-semibold uppercase">
                  480p High
                </span>
              </div>
              <div class="p-3 flex-grow flex flex-col justify-between gap-3">
                <div class="font-mono text-[10px] text-mute flex items-center justify-between">
                  <span>Dimension: 640&nbsp;&times;&nbsp;480</span>
                  <span class="text-primary font-semibold">JPEG</span>
                </div>
                <div class="grid grid-cols-3 gap-2">
                  <button 
                    type="button" 
                    class="h-8 bg-primary hover:bg-primary/95 text-on-primary text-xs font-semibold rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center gap-1 col-span-2 btn-download-thumb"
                    data-type="hqdefault"
                    aria-label="Download 480p High Quality Thumbnail File"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                    <span>Download</span>
                  </button>
                  <button 
                    type="button" 
                    class="h-8 bg-canvas border border-hairline hover:bg-canvas-soft-2 text-primary text-xs font-medium rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center btn-copy-thumb"
                    data-type="hqdefault"
                    aria-label="Copy 480p Thumbnail to Clipboard"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-5 10v-3m0 0l-1.5 1.5M12 12l1.5 1.5" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>

            <!-- Thumbnail Option Card: MQ (360p) -->
            <div class="border border-hairline bg-canvas rounded-sm overflow-hidden flex flex-col shadow-level-2 group" id="card-thumbnail-mq">
              <div class="relative aspect-video bg-canvas-soft-2 border-b border-hairline overflow-hidden">
                <img id="thumb-img-mq" src="" alt="Medium Quality Thumbnail" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" loading="lazy" />
                <span class="absolute top-2 left-2 px-2 py-0.5 bg-primary/80 backdrop-blur-sm text-on-primary font-mono text-[9px] rounded-sm font-semibold uppercase">
                  360p Medium
                </span>
              </div>
              <div class="p-3 flex-grow flex flex-col justify-between gap-3">
                <div class="font-mono text-[10px] text-mute flex items-center justify-between">
                  <span>Dimension: 480&nbsp;&times;&nbsp;360</span>
                  <span class="text-primary font-semibold">JPEG</span>
                </div>
                <div class="grid grid-cols-3 gap-2">
                  <button 
                    type="button" 
                    class="h-8 bg-primary hover:bg-primary/95 text-on-primary text-xs font-semibold rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center gap-1 col-span-2 btn-download-thumb"
                    data-type="mqdefault"
                    aria-label="Download 360p Medium Quality Thumbnail File"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                    <span>Download</span>
                  </button>
                  <button 
                    type="button" 
                    class="h-8 bg-canvas border border-hairline hover:bg-canvas-soft-2 text-primary text-xs font-medium rounded-xs shadow-level-2 transition-colors cursor-pointer flex items-center justify-center btn-copy-thumb"
                    data-type="mqdefault"
                    aria-label="Copy 360p Thumbnail to Clipboard"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-5 10v-3m0 0l-1.5 1.5M12 12l1.5 1.5" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Interactive Information & Features Section -->
  <section id="features" class="relative z-10 max-w-[1200px] mx-auto border-t border-hairline pt-16 mb-20" aria-labelledby="features-title">
    <div class="text-center max-w-[600px] mx-auto mb-12">
      <h2 id="features-title" class="font-mono text-xs uppercase tracking-widest text-primary font-semibold mb-2">Designed for Creators</h2>
      <p class="text-xl md:text-2xl font-semibold tracking-display-md text-primary text-pretty leading-none">
        No loops. No spam. Instant outputs.
      </p>
    </div>

    <!-- 3-Column Marketing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Feature Card 1 -->
      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3">
        <div class="w-8 h-8 rounded-full bg-link/10 text-link flex items-center justify-center mb-4" aria-hidden="true">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-primary tracking-display-sm">Functional Image Grabs</h3>
        <p class="text-xs text-body-text mt-2 leading-relaxed">
          Competitor sites open image links in separate tabs, forcing you to right-click and save manually. Our system converts streams to blobs, downloading files directly.
        </p>
      </div>

      <!-- Feature Card 2 -->
      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3">
